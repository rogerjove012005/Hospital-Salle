POSTGRES_DB=hospital
POSTGRES_USER=hospital
POSTGRES_PASSWORD=hospital
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket opcional donde la API guarda una copia del CSV tras import nuevo (PostgreSQL sigue siendo la fuente estructural)
MINIO_CSV_INGEST_BUCKET=hospital-csv-ingest
# 1 = no subir copia raw a MinIO aunque el servicio exista
MINIO_CSV_INGEST_DISABLED=0

API_PORT=8000

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=rogerjove012005@gmail.com
PGADMIN_DEFAULT_PASSWORD=hospital

JWT_SECRET=dev-only-change-me
ADMIN_EMAIL=rogerjove012005@gmail.com
ADMIN_PASSWORD=hospital

# Ingesta automatizada (csv-ingest-worker): cuenta con rol permitido (/imports/csv) — mismo admin seed por defecto
# Lista separada por comas vacía las URLs para sólo vigilancia de carpeta (inbox)
CSV_PULL_URLS=http://mock-hospital-feed/export.csv
INGEST_POLL_INTERVAL_SECONDS=90
INGEST_HTTP_TIMEOUT_SECONDS=120
INGEST_LOG_LEVEL=INFO
MOCK_HOSPITAL_FEED_PORT=8099

FRONTEND_PORT=3000

# Frontend -> API (same-origin proxy in nginx)
API_BASE_URL=/api
# URL mostrada al usuario para abrir la UI de Mailpit (recuperar contraseña)
MAILPIT_UI_URL=http://localhost:8025

# API CORS (comma-separated)
CORS_ALLOW_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Public base URL where the frontend is reachable
APP_BASE_URL=http://localhost:3000

# Mailpit (Docker compose por defecto): recibe el correo de “olvidé contraseña” en
#   http://localhost:8025  (SMTP del contenedor: mailpit:1025, sin TLS).
# Para Gmail u otro SMTP real, descomenta y rellena; pon SMTP_USE_STARTTLS=1 y p. ej. puerto 587.
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@lasallesanidad.com
SMTP_FROM_NAME=laSalle Health Center
SMTP_USE_SSL=0
SMTP_USE_STARTTLS=0
# Ejemplo producción (Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASSWORD=contraseña_de_aplicación
# SMTP_FROM=tu_correo@gmail.com
# SMTP_USE_STARTTLS=1
